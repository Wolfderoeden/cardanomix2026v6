# Server
PORT=8787
NODE_ENV=development
APP_ORIGIN=http://127.0.0.1:5173
SESSION_SECRET=replace-with-a-long-random-secret

# Admin bootstrap. Run `pnpm seed:admin` after setting these.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Binance
BINANCE_API_BASE=https://api.binance.com
ADA_QUOTE_CURRENCY=USD

# PayPal Checkout
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_RETURN_URL=https://cardanomix2026.netlify.app/
PAYPAL_CANCEL_URL=https://cardanomix2026.netlify.app/
PAYPAL_FALLBACK_URL=
PAYPAL_CUSTOM_ADA_LINK=
